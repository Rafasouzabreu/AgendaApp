@model AgendaApp.MVC.Models.Account.AccountRegisterViewModel

@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="row">
    <div class="col-md-4 offset-md-4">
        <div class="card">
            <div class="card-body">
                <div class="text-center">
                    <img src="https://www.cotiinformatica.com.br/imagens/logo-coti-informatica.svg" />
                    <h4>Agenda de Tarefas</h4>
                    <p>Criar Conta de Usuário</p>
                </div>

                @using (Html.BeginForm())
                {
                    <div class="mb-3">
                        <label>Nome do usuário:</label>
                        @Html.TextBoxFor(model => model.Nome, new { @class = "form-control" })
                    </div>

                    <div class="mb-3">
                        <label>Email de acesso:</label>
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control" })
                    </div>

                    <div class="mb-3">
                        <label>Senha de acesso:</label>
                        @Html.PasswordFor(model => model.Senha, new { @class = "form-control" })
                    </div>

                    <div class="mb-3">
                        <label>Confirme sua senha:</label>
                        @Html.PasswordFor(model => model.SenhaConfirmacao, new { @class = "form-control" })
                    </div>

                    <div class="mb-3 d-grid">
                        <input type="submit" class="btn btn-success btn-sm" value="Realizar Cadastro" />
                    </div>

                    <div class="mb-3 d-grid">
                        <a href="/Account/Login" class="btn btn-light btn-sm">
                            Já possui conta? <strong>Acesse aqui!</strong>
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>


