<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TarefasApp.MVC</title>
    <link href="~/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <nav class="navbar navbar-expand-md navbar-dark bg-primary">
        <a class="navbar-brand ms-5" href="#">TarefasApp.MVC</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/Tarefas/Consulta">Consultar Tarefas</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Account/Logout">Sair do Sistema</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container mt-3">
        <div class="card">
            <div class="card-body">
                <h5>Consulta de tarefas</h5>
                <p>Pesquise as tarefas em sua agenda:</p>

                @model AgendaApp.MVC.Models.Tarefas.TarefasConsultaViewModel

                @using (Html.BeginForm())
                {
                    <div class="row">
                        <div class="col-md-3">
                            @Html.TextBoxFor(model => model.DataInicio,
                                     new { @class = "form-control", @type = "date" })
                        </div>
                        <div class="col-md-3">
                            @Html.TextBoxFor(model => model.DataFim,
                                     new { @class = "form-control", @type = "date" })
                        </div>
                        <div class="col-md-6">
                            <input type="submit" class="btn btn-primary"
                                   value="Consultar tarefas" />
                        </div>
                    </div>
                }

                <div class="mt-3">
                    @TempData["ConsultaTarefas"]
                </div>

            </div>
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>



